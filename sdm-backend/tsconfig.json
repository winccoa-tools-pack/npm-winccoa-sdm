{
  "$schema": "https://json.schemastore.org/tsconfig",
  "include": ["./src/**/*"],
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "node16",
    "target": "es2021",
    "lib": ["es2021"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "declaration": false
  }
}
